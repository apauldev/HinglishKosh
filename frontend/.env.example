# Cloudflare API token (DO NOT COMMIT — set as secret in CI or ~/.wrangler)
# Generate at: https://dash.cloudflare.com/profile/api-tokens
# Needed permissions: D1 (edit), Pages (edit)
CLOUDFLARE_API_TOKEN=

# D1 database UUID (from `wrangler d1 list`)
# Set after: wrangler d1 create hinglishkosh
CLOUDFLARE_D1_ID=

# Turnstile keys (only if you enable Turnstile on the search forms)
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
